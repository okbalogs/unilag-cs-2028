{
  "app": {
    "name": "BTController",
    "version": "1.0",
    "entry_screen": "ScanScreen"
  },
  "screens": [
    {
      "name": "ScanScreen",
      "background": "#121212",
      "components": [
        {
          "type": "text",
          "value": "Find Devices",
          "size": 24,
          "bold": true,
          "color": "#FFFFFF"
        },
        {
          "type": "button",
          "label": "Start Scan",
          "color": "#00C853",
          "on_click": [
            {
              "action": "call",
              "method": "bluetooth.scan(duration=10)"
            }
          ]
        },
        {
          "type": "list",
          "id": "device_list",
          "source": "found_devices",
          "empty_text": "No devices found yet...",
          "item_template": {
            "text": "$device.name",
            "subtext": "$device.mac_address",
            "icon": "bluetooth",
            "on_tap": [
              {
                "action": "run_script",
                "script": "attempt_connect"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "ControlScreen",
      "background": "#121212",
      "components": [
        {
          "type": "text",
          "value": "Connected to $active_device.name",
          "size": 20,
          "color": "#FFFFFF"
        },
        {
          "type": "button",
          "label": "Send Ping",
          "color": "#4A90E2",
          "on_click": [
            {
              "action": "call",
              "method": "bluetooth.send(data=\"PING\")"
            }
          ]
        },
        {
          "type": "button",
          "label": "Disconnect",
          "color": "#FF1744",
          "on_click": [
            {
              "action": "call",
              "method": "bluetooth.disconnect()"
            },
            {
              "action": "navigate",
              "target": "ScanScreen"
            }
          ]
        }
      ]
    }
  ],
  "scripts": [
    {
      "name": "attempt_connect",
      "steps": [
        {
          "action": "show_toast",
          "message": "Connecting to $tapped_device.name"
        },
        {
          "action": "call",
          "method": "bluetooth.connect($tapped_device.mac)"
        },
        {
          "action": "if",
          "condition": "bluetooth.status == connected",
          "then": [
            {
              "action": "store",
              "variable": "active_device",
              "value": "$tapped_device"
            },
            {
              "action": "navigate",
              "target": "ControlScreen"
            }
          ],
          "else": [
            {
              "action": "show_toast",
              "message": "Could not connect"
            }
          ]
        }
      ]
    }
  ],
  "services_required": [
    "bluetooth"
  ]
}
